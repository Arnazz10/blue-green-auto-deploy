pipeline {
    agent any

    environment {
        REGISTRY = "registry.hub.docker.com"
        IMAGE_NAME = "arnazz10/shiftops-app"
        VERSION = "v2.1.${BUILD_NUMBER}"
        NAMESPACE_BLUE = "production-blue"
        NAMESPACE_GREEN = "production-green"
    }

    stages {
        stage('Source Checkout') {
            steps {
                echo "Cloning repository..."
                checkout scm
            }
        }

        stage('Docker Build') {
            steps {
                echo "Building image ${IMAGE_NAME}:${VERSION}..."
                // sh "docker build -t ${IMAGE_NAME}:${VERSION} ."
            }
        }

        stage('Push to Registry') {
            steps {
                echo "Pushing ${IMAGE_NAME}:${VERSION} to ${REGISTRY}..."
                // sh "docker push ${IMAGE_NAME}:${VERSION}"
            }
        }

        stage('Deploy to Green') {
            steps {
                echo "Applying manifests to ${NAMESPACE_GREEN}..."
                // sh "kubectl apply -f k8s/deployment-green.yaml -n ${NAMESPACE_GREEN}"
                // sh "kubectl set image deployment/shiftops-app-green server=${IMAGE_NAME}:${VERSION} -n ${NAMESPACE_GREEN}"
            }
        }

        stage('Smoke Tests') {
            steps {
                echo "Waiting for pods to be ready..."
                // sh "kubectl rollout status deployment/shiftops-app-green -n ${NAMESPACE_GREEN}"
                echo "Running endpoint checks..."
                // sh "curl -f https://green.shiftops.internal/health"
            }
        }

        stage('Await Traffic Switch') {
            steps {
                input message: "Promote ${VERSION} to Production (Green)?", ok: "Promote"
                echo "Confirming traffic switch in ShiftOps Dashboard..."
            }
        }
        
        stage('Teardown Standby') {
            steps {
                echo "Scaling down old environment (Blue)..."
                // sh "kubectl scale deployment/shiftops-app-blue --replicas=1 -n ${NAMESPACE_BLUE}"
            }
        }
    }

    post {
        success {
            echo "Deployment successful!"
        }
        failure {
            echo "Deployment failed. Rolling back..."
        }
    }
}
